{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": "https://localhost,https://localhost:443"
  },
  "Caching": {
    "DefaultDurationSeconds": 300,
    "Profiles": [
      { "Name": "songs", "CacheDurationSeconds": 600 },
      { "Name": "audio", "CacheDurationSeconds": 3600 },
      { "Name": "cover", "CacheDurationSeconds": 3600 }
    ]
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  }
}
